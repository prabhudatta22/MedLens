# PostgreSQL connection (Neon, Supabase, RDS, local Postgres, etc.)
# Radiant DB: if your provider gives a Postgres URL, paste it here.
DATABASE_URL=postgresql://user:password@localhost:5432/medlens

PORT=3000

# PostgreSQL connection pool (default 10). Raise under load/stress; stay below DB max_connections / PgBouncer.
# PGPOOL_MAX=80

# Load/stress: when set, exposes POST /api/load-test/session — remove when not testing.
# LOAD_TEST_TOKEN=

# ABHA / ABDM (Ayushman Bharat Digital Mission) — optional. Links Health ID to the consumer profile.
# Integration mode: stub (default, no external calls), live (requires ABDM credentials + implemented flows), off.
ABHA_INTEGRATION_MODE=stub
# In stub mode, Aadhaar OTP verification accepts this fixed OTP (demo only).
ABHA_STUB_AADHAAR_OTP=123456
# Live mode (when ABHA_INTEGRATION_MODE=live or when ABDM_CLIENT_ID + ABDM_CLIENT_SECRET are set):
# ABDM_CLIENT_ID=
# ABDM_CLIENT_SECRET=
# ABDM_ACCESS_TOKEN=   # short-lived; replace with gateway token flow in production
# ABDM_HEALTH_ID_API_BASE=https://healthidsbx.abdm.gov.in/api
# ABDM_PROFILE_FETCH_PATH=/v2/account/profile
# ABDM_PROFILE_UPDATE_PATH=/v2/account/profile
# ABDM_HIP_ID=

# Razorpay (https://razorpay.com/docs/api/) — optional; required for diagnostics prepaid (Orders + Checkout).
# Use separate Dashboard apps or key pairs for test vs live — never mix secrets across environments.
# Webhook URL (HTTPS in production): https://<your-host>/webhook/razorpay — subscribe to payment.captured, payment.failed, refund.processed.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Set to 1 in production if all flows settle only after capture (not authorization-only).
# RAZORPAY_REQUIRE_CAPTURED_ONLY=0
#
# Rate limits for POST /api/payments/razorpay/order (per logged-in user; single Node process — use edge/redis limits when scaled out).
# RAZORPAY_ORDER_RATE_WINDOW_MS=900000
# RAZORPAY_ORDER_RATE_MAX=40
#
# JSON audit logs to stdout (Stripe-like grep): payments component + webhook/refund tags.
# PAYMENTS_LOG_JSON=0
#
# Protect GET /api/payments/razorpay/metrics — header X-Payments-Metrics-Secret must match.
# PAYMENTS_METRICS_SECRET=

# Reverse-proxy / load balancer (nginx, Render, Fly, ALB). Sets Express trust proxy for correct client IP + secure cookies.
# TRUST_PROXY=1

# NODE_ENV=production

# Redis (required for Service Provider sessions)
# Example (local docker): redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API (Meta) — optional
# You need a WhatsApp Business app + phone number.
# Webhook endpoint in this app: /webhook/whatsapp
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=EAA...your_token...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Public base URL for deep links sent back to WhatsApp
APP_BASE_URL=http://localhost:3000

# OTP auth (dev defaults). CHANGE in production.
OTP_PEPPER=change-me-super-secret
OTP_EXPIRES_MINUTES=5
SESSION_DAYS=30

# Service Provider login:
# Seed creates username=admin password=admin in Postgres.

# Google Maps — Geocoding API (optional). Enables “Use my location” on the home page:
# browser geolocation → server reverse-geocode → full address + auto-pick demo city when possible.
# Create a key in Google Cloud, enable “Geocoding API”, restrict by IP or HTTP referrer as appropriate.
# GOOGLE_MAPS_API_KEY=

# --- Partner JSON APIs (sanctioned feeds; one block per retailer) ---
# Each brand issues base URL + credentials under contract. Without these, online compare
# returns data_mode=unconfigured (no fabricated price). For local UI demos only:
# ONLINE_USE_ILLUSTRATIVE_FALLBACK=true
#
# Common optional vars per prefix (PREFIX = MEDPLUS | APOLLO | NETMEDS | ONE_MG | MEDKART):
#   {PREFIX}_PARTNER_SEARCH_PATH=/search          (default /search)
#   {PREFIX}_PARTNER_SEARCH_METHOD=GET            (or POST)
#   {PREFIX}_PARTNER_QUERY_PARAM=q                (GET query param name)
#   {PREFIX}_PARTNER_BEARER_TOKEN=                (or use API key below)
#   {PREFIX}_PARTNER_API_KEY=
#   {PREFIX}_PARTNER_API_KEY_HEADER=X-API-Key
#   {PREFIX}_PARTNER_EXTRA_HEADERS_JSON={"X-Platform":"desktop"}
#   {PREFIX}_PARTNER_POST_BODY_TEMPLATE={"q":{{queryJson}}}   (POST only; {{queryJson}} is JSON-string)
#
# Tata 1mg merchant APIs (JWT/Bearer from onboarding): https://onedoc.1mg.com/public_docs/docs/merchant/1.0.0
# Example (your paths will match the contract you receive):
# ONE_MG_PARTNER_API_BASE=https://api.example-from-1mg.com
# ONE_MG_PARTNER_SEARCH_PATH=/v1/merchant/search
# ONE_MG_PARTNER_BEARER_TOKEN=eyJhbG...
#
# MEDPLUS_PARTNER_API_BASE=
#
# MedPlus Mart — optional consumer catalog search (same XHR their site uses; not a B2B contract).
# Copy tokenId from browser DevTools → Network → getProductSearch. Expires; refresh on 403/HTML errors.
# MEDPLUS_CATALOG_TOKEN_ID=paste_tokenId_from_getProductSearch
# MEDPLUS_CATALOG_PAGE_SIZE=15
# MEDPLUS_CATALOG_USER_AGENT=Mozilla/5.0 ...   (optional; default mimics desktop Chrome)
#
# Apollo Pharmacy — optional consumer search (search.apollo247.com/v4/search).
# Copy the Authorization header value from DevTools (may be a static token, not "Bearer …").
# APOLLO_CATALOG_AUTHORIZATION=paste_authorization_header_value
# APOLLO_CATALOG_PINCODE=400001
# APOLLO_CATALOG_USER_AGENT=Mozilla/5.0 ...
#
# Netmeds — optional consumer search (/ext/search/application/api/v1.0/products).
# Copy Authorization: Bearer … from DevTools. Optional NETMEDS_CATALOG_LOCATION_JSON overrides pincode/city.
# NETMEDS_CATALOG_BEARER=paste_bearer_token_without_Bearer_prefix
# NETMEDS_CATALOG_AUTHORIZATION=Bearer paste_token   (alternative: full header value)
# NETMEDS_CATALOG_LOCATION_JSON={"country":"INDIA","country_iso_code":"IN","pincode":"110001","city":"Delhi","state":"Delhi"}
# NETMEDS_CATALOG_PAGE_SIZE=12
# NETMEDS_CATALOG_USER_AGENT=Mozilla/5.0 ...
# APOLLO_PARTNER_API_BASE=
# NETMEDS_PARTNER_API_BASE=
# MEDKART_PARTNER_API_BASE=
#
# ONLINE_USE_ILLUSTRATIVE_FALLBACK=false
# PARTNER_HTTP_TIMEOUT_MS=12000
