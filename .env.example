# PostgreSQL connection (Neon, Supabase, RDS, local Postgres, etc.)
# Radiant DB: if your provider gives a Postgres URL, paste it here.
DATABASE_URL=postgresql://user:password@localhost:5432/medlens

PORT=3000

# WhatsApp Cloud API (Meta) — optional
# You need a WhatsApp Business app + phone number.
# Webhook endpoint in this app: /webhook/whatsapp
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=EAA...your_token...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Public base URL for deep links sent back to WhatsApp
APP_BASE_URL=http://localhost:3000

# OTP auth (dev defaults). CHANGE in production.
OTP_PEPPER=change-me-super-secret
OTP_EXPIRES_MINUTES=5
SESSION_DAYS=30

# --- Partner JSON APIs (sanctioned feeds; one block per retailer) ---
# Each brand issues base URL + credentials under contract. Without these, online compare
# returns data_mode=unconfigured (no fabricated price). For local UI demos only:
# ONLINE_USE_ILLUSTRATIVE_FALLBACK=true
#
# Common optional vars per prefix (PREFIX = MEDPLUS | APOLLO | NETMEDS | ONE_MG | MEDKART):
#   {PREFIX}_PARTNER_SEARCH_PATH=/search          (default /search)
#   {PREFIX}_PARTNER_SEARCH_METHOD=GET            (or POST)
#   {PREFIX}_PARTNER_QUERY_PARAM=q                (GET query param name)
#   {PREFIX}_PARTNER_BEARER_TOKEN=                (or use API key below)
#   {PREFIX}_PARTNER_API_KEY=
#   {PREFIX}_PARTNER_API_KEY_HEADER=X-API-Key
#   {PREFIX}_PARTNER_EXTRA_HEADERS_JSON={"X-Platform":"desktop"}
#   {PREFIX}_PARTNER_POST_BODY_TEMPLATE={"q":{{queryJson}}}   (POST only; {{queryJson}} is JSON-string)
#
# Tata 1mg merchant APIs (JWT/Bearer from onboarding): https://onedoc.1mg.com/public_docs/docs/merchant/1.0.0
# Example (your paths will match the contract you receive):
# ONE_MG_PARTNER_API_BASE=https://api.example-from-1mg.com
# ONE_MG_PARTNER_SEARCH_PATH=/v1/merchant/search
# ONE_MG_PARTNER_BEARER_TOKEN=eyJhbG...
#
# MEDPLUS_PARTNER_API_BASE=
# APOLLO_PARTNER_API_BASE=
# NETMEDS_PARTNER_API_BASE=
# MEDKART_PARTNER_API_BASE=
#
# ONLINE_USE_ILLUSTRATIVE_FALLBACK=false
# PARTNER_HTTP_TIMEOUT_MS=12000
